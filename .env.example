# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- GreenAPI (WhatsApp) ---
# Get these from https://console.green-api.com/
GREEN_API_INSTANCE_ID=1101000001
GREEN_API_TOKEN=d75b3a66374942c5b3c019c698abc2067e151558acbd412345
# Optional: override default base URL
GREEN_API_HOST=https://api.green-api.com
GREEN_API_MEDIA_HOST=https://media.green-api.com

# --- Database ---
# Inside docker-compose the host is "postgres". For local dev use "localhost".
DATABASE_URL=postgresql+psycopg2://propeller:propeller@postgres:5432/propeller_bot

# --- Chroma vector store ---
# Inside docker-compose the host is "chroma". For local dev use "localhost".
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=propeller_knowledge

# --- Website / knowledge sources ---
PROPELLER_WEBSITE_BASE=https://propeller-drones.com

# --- Sales handoff (LeadMe CRM) ---
# Two integration paths (choose one via LEADME_MODE):
#
#   session  -> POST directly to the internal /app/leads/leadAction endpoint
#               using a PHP session cookie (needs periodic manual refresh
#               because LeadMe login is protected by reCAPTCHA).
#   webhook  -> POST to a public "external interface" URL that LeadMe
#               support has to provision for us (same as Facebook / TikTok
#               lead ads). This is the recommended long-term path.
LEADME_MODE=webhook

# ---- webhook mode ----
LEADME_API_URL=
LEADME_API_TOKEN=
# One of: Bearer | Token | Basic | Query | None
LEADME_AUTH_SCHEME=Bearer
# If AUTH_SCHEME=Query, key name for the api token query-param
LEADME_AUTH_QUERY_KEY=api_key
# json | form
LEADME_WEBHOOK_ENCODING=json
# Optional JSON overriding the default internal->external field names.
# See app/crm/leadme_client.py DEFAULT_FIELD_MAP for the internal keys.
# Example:
# LEADME_FIELD_MAP={"phone":"phone","name":"full_name","status":"status","note":"comments"}
LEADME_FIELD_MAP=

# ---- session mode ----
# Get these by running leadme-recon/login_persistent.py locally, then
# copying values from the created captures/cookies.json:
#   PHPSESSID           -> LEADME_PHPSESSID
#   csrf_cookie_name    -> LEADME_CSRF_COOKIE  and  LEADME_CSRF_TOKEN
# Both csrf values must be the same string. Session cookies expire, so
# treat this as short-term only.
LEADME_PHPSESSID=
LEADME_CSRF_COOKIE=
LEADME_CSRF_TOKEN=
# 12277 = the existing "leads from WhatsApp" campaign (verified during recon)
LEADME_CAMPAIGN_ID=12277
LEADME_STATUS_ID=1

# ---- shared ----
LEADME_READY_STATUS=ready_for_call
LEADME_SOURCE_LABEL=WhatsApp Bot

# --- Bot behavior ---
# Comma-separated list of phone numbers (digits only, no +) allowed to talk to
# the bot. Leave empty to allow anyone (production default).
ALLOWED_TEST_PHONES=

# Logging
LOG_LEVEL=INFO
