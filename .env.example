# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- GreenAPI (WhatsApp) ---
# Get these from https://console.green-api.com/
GREEN_API_INSTANCE_ID=1101000001
GREEN_API_TOKEN=d75b3a66374942c5b3c019c698abc2067e151558acbd412345
# Optional: override default base URL
GREEN_API_HOST=https://api.green-api.com
GREEN_API_MEDIA_HOST=https://media.green-api.com

# --- Database ---
# Inside docker-compose the host is "postgres". For local dev use "localhost".
DATABASE_URL=postgresql+psycopg2://propeller:propeller@postgres:5432/propeller_bot

# --- Chroma vector store ---
# Inside docker-compose the host is "chroma". For local dev use "localhost".
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=propeller_knowledge

# --- Website / knowledge sources ---
PROPELLER_WEBSITE_BASE=https://propeller-drones.com

# --- Sales handoff (LeadMe CRM) ---
# LeadMe integrates via a public "supplier" API -- same mechanism they use
# for Facebook / TikTok lead ads. No auth headers, just the URL. Provision
# it in LeadMe under Preferences -> Suppliers -> {supplier} -> API dialog:
#
# INSERT URL (creates or upserts by phone within the campaign):
#   https://api.leadmecms.co.il/supplier/insert/{link_id}/{slug}
#
# UPDATE URL (updates status/comment of an existing lead by phone):
#   https://api.leadmecms.co.il/supplier/update/p/{slug}
#
# The account already has a supplier named "AI WhatsApp Bot" (id 2318)
# linked to campaign 12277 ("leads from WhatsApp"). Slug: 1g9DqcYa.
LEADME_INSERT_URL=https://api.leadmecms.co.il/supplier/insert/1510071/1g9DqcYa
LEADME_UPDATE_URL=https://api.leadmecms.co.il/supplier/update/p/1g9DqcYa
# Status id or name to set after a successful insert (empty => skip update).
# Get valid ids from the campaign status list in LeadMe. 1 = "New".
LEADME_STATUS_ID=1
# Value sent in the `tags` field on every lead push.
LEADME_SOURCE_LABEL=WhatsApp Bot

# --- LeadMe internal admin (for delete-lead from our /admin UI) ---
# LeadMe's public "supplier" API only supports insert+update, not delete.
# For manual QA (wipe a phone from LeadMe so re-submitting the form treats
# it as a new lead) we call LeadMe's internal admin endpoint using saved
# session cookies. Export cookies from a logged-in Chrome tab
# (DevTools -> Application -> Cookies) into this JSON file. Empty path
# => admin delete only wipes our local DB, LeadMe is left alone.
LEADME_COOKIES_PATH=data/leadme_cookies.json
LEADME_ADMIN_BASE=https://www.leadmecms.co.il

# --- Bot behavior ---
# Comma-separated list of phone numbers (digits only, no +) allowed to talk to
# the bot. Leave empty to allow anyone (production default).
ALLOWED_TEST_PHONES=

# --- Inbound webhook (LeadMe -> bot) ---
# LeadMe hits POST /webhook/leadme/{WEBHOOK_SECRET} when a new lead
# arrives on a subscribed campaign, and the bot immediately sends a
# WhatsApp opener. Keep this secret non-empty in production -- any URL
# that leaks becomes a spam vector.
WEBHOOK_SECRET=change-me-to-a-long-random-string
# Container-internal port uvicorn listens on. The docker-compose file maps
# host 127.0.0.1:${WEBHOOK_HOST_PORT:-8082} -> container 8080.
WEBHOOK_PORT=8080
# Override the host-side port if 8082 is taken on this machine.
WEBHOOK_HOST_PORT=8082

# --- Admin UI (browse lead conversations) ---
# HTTP Basic auth for the /admin routes on the webhook server. If either is
# empty the admin UI refuses to serve anything (fail-closed). Use a strong
# random password -- this UI exposes every lead conversation.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-long-random-string

# --- Webinar follow-up ---
# How many hours after the 55-min webinar was sent before we ping the lead
# with "did you watch it? what did you think?". Only sent once per lead.
WEBINAR_FOLLOWUP_HOURS=6

# --- Follow-up nudges (wake-up messages for silent leads) ---
# When ON, a background scheduler wakes silent leads with a canned Hebrew
# nudge. Only fires when: last message was OURS, funnel_stage != handed_off,
# and current Israel-local time is inside the quiet window.
FOLLOWUP_ENABLED=true
# How often the scheduler wakes up to scan the DB (minutes). Keep this small
# vs. FOLLOWUP_FIRST_HOURS so we don't drift.
FOLLOWUP_INTERVAL_MINUTES=30
# Hours of silence before the FIRST nudge fires.
FOLLOWUP_FIRST_HOURS=24
# Additional hours after nudge #1 before the SECOND (and last) nudge fires.
FOLLOWUP_SECOND_HOURS=72
# Hard cap on nudges per lead. 2 is a good default; anything more feels spammy.
FOLLOWUP_MAX_NUDGES=2
# Polite window (Asia/Jerusalem local hour, 0-23). Nudges only send inside
# [start, end). 9-20 means: send between 09:00 and 19:59.
FOLLOWUP_QUIET_START_HOUR=9
FOLLOWUP_QUIET_END_HOUR=20

# Logging
LOG_LEVEL=INFO
